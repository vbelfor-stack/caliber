# CALIBER v3 — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Required — Anthropic API key for synthesis
ANTHROPIC_API_KEY=

# Required — password for the web frontend (Phase 4)
APP_PASSWORD=

# Optional — AlphaVantage cross-check feed (degrades to medium-confidence if absent)
# Free tier: 25 req/day. Premium: 500/day. Get key at alphavantage.co
ALPHAVANTAGE_API_KEY=

# Optional — FRED 10Y rate feed (degrades gracefully if absent)
FRED_API_KEY=
